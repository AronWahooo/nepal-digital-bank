# ─────────────────────────────────────────────────────────────────────────────
# Nepal Digital Bank — Environment Variables
# Copy this to .env and fill in real values (never commit .env to git!)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Render provides this automatically) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://bankuser:bankpass@localhost/bankdb

# ─── Redis (Render provides this automatically) ───────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-here

# Generate with Python: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production

# ─── CORS — set to your actual frontend URL ───────────────────────────────────
ALLOWED_ORIGINS=["https://yourapp.onrender.com","http://localhost:3000"]

# ─── Sparrow SMS (Nepal) — get token from https://sparrowsms.com ──────────────
SPARROW_SMS_TOKEN=your-sparrow-sms-api-token
SPARROW_SMS_FROM=NepalBank

# ─── Admin account (created on first run) ────────────────────────────────────
ADMIN_EMAIL=admin@nepalbank.com
ADMIN_PASSWORD=YourSecureAdminPassword123!
